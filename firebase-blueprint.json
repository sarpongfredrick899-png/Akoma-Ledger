{
  "entities": {
    "Transaction": {
      "title": "Transaction",
      "description": "Financial record of business activity",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "date": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["income", "expense", "credit"] },
        "category": { "type": "string" },
        "quantity": { "type": "string" },
        "product": { "type": "string" },
        "directCost": { "type": "number" },
        "grossProfit": { "type": "number" },
        "netProfit": { "type": "number" },
        "rawText": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["id", "userId", "date", "description", "amount", "type", "category", "timestamp"]
    },
    "ProductCost": {
      "title": "Product Cost",
      "description": "Inventory item and its cost price",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "costPrice": { "type": "number" }
      },
      "required": ["userId", "name", "costPrice"]
    }
  },
  "firestore": {
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Collection of business transactions"
    },
    "/productCosts/{productId}": {
      "schema": "ProductCost",
      "description": "User defined product costs"
    }
  }
}
